{
  "name": "wxt-starter",
  "description": "manifest.json description",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:script": "node scripts/dev.mjs",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test:integration": "npm run build && playwright test",
    "test:integration:install": "playwright install chromium",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "numeric": "^1.2.6",
    "webgazer": "^3.5.3"
  }
}
